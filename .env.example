APP_ENV=development
DEBUG=true

# PostgreSQL (app)
DATABASE_URL=postgresql+asyncpg://seekbind:seekbind@localhost:5432/seekbind
POSTGRES_USER=seekbind
POSTGRES_PASSWORD=seekbind
POSTGRES_DB=seekbind

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=seekbind_providers

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4.1-mini

# Ollama (fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
OLLAMA_LLM_MODEL=qwen3:7b

# SerpAPI (veri toplama)
SERPAPI_API_KEY=

# Langfuse (app tarafı - trace göndermek için)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Langfuse (docker-compose - kendi veritabanı ve auth secret'ları)
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfuse
LANGFUSE_DB_NAME=langfuse
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
