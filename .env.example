APP_ENV=development
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://seekbind:seekbind@localhost:5432/seekbind

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=seekbind_providers

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# Ollama (fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
OLLAMA_LLM_MODEL=qwen3:7b

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
